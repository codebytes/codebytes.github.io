[codespell]
# Skip machine-generated / minified files that are full of hashes and
# tokens which trigger false positives (e.g. package-lock.json:"vEw").
skip = *package-lock.json,*.lock,*.min.js,*.min.css
# Domain terms and valid words codespell misreads as typos:
#   aks          - Azure Kubernetes Service (flagged as "ask")
#   statics      - static members/methods (flagged as "statistics")
#   implementors - valid variant; also appears in external URLs
ignore-words-list = aks,statics,implementors
